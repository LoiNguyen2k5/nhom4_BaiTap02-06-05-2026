PORT=3000

# FaceID Configuration
FACE_MATCH_THRESHOLD=0.55

# Cấu hình Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nhom4_baitap

# JWT Secret Key (thay bằng chuỗi ngẫu nhiên dài >=32 ký tự)
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Google Gemini AI (dùng cho phân tích CV tự động - HR AI)
# Lấy API key tại: https://aistudio.google.com/app/apikey
# Nếu để trống, hệ thống sẽ dùng mock data thay thế
GEMINI_API_KEY=

# CORS - Frontend origins được phép gọi API (cách nhau bằng dấu phẩy)
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5200

# Cấu hình Email (Gmail SMTP)
# Dùng App Password 16 ký tự (không phải password Gmail thường)
# Tạo tại: Google Account > Security > 2-Step Verification > App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_16_chars
